# Telegram Bot
BOT_TOKEN=

# PostgreSQL (홈서버 shared-postgres)
DB_HOST=shared-postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=nihongo
DB_SSLMODE=disable

# Redis (프로젝트 전용)
REDIS_HOST=nihongo-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Gemini API
GEMINI_API_KEY=

# Scheduler
DAILY_CRON_ENABLED=true
NHK_CRAWL_CRON=0 3 * * *
QUIZ_BATCH_CRON=0 4 * * *

# App Config
DEFAULT_TIMEZONE=Asia/Seoul
MAX_DAILY_QUIZZES=10
MAX_REVIEW_CARDS=20
